{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/pressure_vessels/governance/policy_exceptions_schema.v1.json",
  "title": "PolicyExceptionsDocument.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "exceptions"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "gate",
          "scope",
          "justification",
          "approver",
          "approved_at",
          "expires_at",
          "linked_backlog_id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "gate": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "justification": {
            "type": "string",
            "minLength": 1
          },
          "approver": {
            "type": "string",
            "pattern": "^@[A-Za-z0-9-]+$"
          },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "linked_backlog_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
