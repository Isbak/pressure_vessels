# Copy this file to `.env` before starting the local runtime integration profile.
# Docker Compose automatically reads `.env` from the repository root.
#
# Example:
#   cp .env.example .env
#   make integration-up

# Host/browser port for the frontend dev server.
FRONTEND_PORT=3000

# Host API port mapped to the backend container.
BACKEND_PORT=8000

# Backend bind address inside the backend container.
BACKEND_HOST=0.0.0.0

# Backend URL reachable from the frontend container on the compose network.
BACKEND_API_BASE_URL=http://backend:8000
